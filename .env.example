# ─────────────────────────────────────────────
#  Bulbul Restaurant — Frontend Environment
#  Copy this file to .env and fill in the values.
#  ✅ Safe to commit — contains no real secrets.
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
VITE_APP_NAME=Bulbul Restaurant
VITE_APP_URL=https://bulbulrestaurant.com
VITE_APP_ENV=production

# ── API ──────────────────────────────────────
VITE_API_BASE_URL=https://api.bulbulrestaurant.com/v1

# ── Reservations ─────────────────────────────
VITE_RESERVATION_PROVIDER=opentable
VITE_RESERVATION_KEY=

# ── Email / Newsletter ────────────────────────
# Web3Forms — free, unlimited submissions, no backend needed
# Sign up at https://web3forms.com → enter your email → copy the Access Key
VITE_WEB3FORMS_KEY=db31615a-6a4d-4666-98c2-385b7eab8cf2

# ── Google Services ───────────────────────────
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_ANALYTICS_ID=

# ── Social Media Links ────────────────────────
VITE_SOCIAL_FACEBOOK=https://facebook.com/bulbulrestaurant
VITE_SOCIAL_INSTAGRAM=https://instagram.com/bulbulrestaurant
VITE_SOCIAL_TWITTER=https://twitter.com/bulbulrestaurant
VITE_SOCIAL_YOUTUBE=https://youtube.com/@bulbulrestaurant

# ── Contact Info ─────────────────────────────
VITE_CONTACT_EMAIL=hello@bulbulrestaurant.com
VITE_CONTACT_PHONE=+44 000 000 0000
VITE_CONTACT_ADDRESS=The Tudor, London

# ── Launch / Coming Soon ─────────────────────
VITE_LAUNCH_DATE=2026-06-01T00:00:00.000Z

# ── Feature Flags ────────────────────────────
VITE_FEATURE_COMING_SOON=true
VITE_FEATURE_ONLINE_BOOKING=false
VITE_FEATURE_BLOG=true
VITE_FEATURE_GALLERY=true
